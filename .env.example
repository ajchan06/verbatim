# Copy this file to .env and fill in your keys.
# `.env` is gitignored — don't commit it.

# Anthropic API key — used for Claude (the LLM that answers questions and judges faithfulness).
# Get one at: https://console.anthropic.com → API Keys
# Add $5 of credits at Settings → Billing. Hard ceiling, no auto-charge.
# This project uses about $3 of that $5.
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI API key — used for embeddings (turning text into vectors for search).
# Get one at: https://www.voyageai.com (free tier covers this project easily)
VOYAGE_API_KEY=pa-...
